{
  "name": "buzzmaster",
  "version": "1.5.0",
  "description": "A buzzer application for quiz shows",
  "productName": "BuzzMaster",
  "author": "marvin-wtt <31454580+marvin-wtt@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/marvin-wtt/BuzzMaster"
  },
  "keywords": [
    "playstation",
    "buzz",
    "buzzer",
    "quiz"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "quasar prepare",
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"See package.json => scripts for available tests.\" && exit 0",
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron",
    "test:unit:ui": "vitest --ui",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run"
  },
  "dependencies": {
    "@quasar/extras": "^1.18.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "events": "^3.3.0",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "^11.1.1",
    "@pinia/testing": "^1.0.3",
    "@quasar/app-vite": "^2.6.0",
    "@quasar/cli": "^4.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.2",
    "@types/w3c-web-hid": "^1.0.7",
    "@vitest/ui": "^4.1.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "electron": "41.2.0",
    "electron-builder": "^26.8.2",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "lodash-es": "^4.18.1",
    "prettier": "^3.8.1",
    "typed-emitter": "^2.1.0",
    "typescript": "^5.9.3",
    "vite-plugin-checker": "^0.12.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
